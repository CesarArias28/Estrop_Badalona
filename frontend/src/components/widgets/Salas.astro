---
// Salas.astro — Flip cards para Sala 1 y Sala 2 con video en la cara frontal

const WA_NUMBER = "15556389717"; // Número de prueba Meta

const salas = [
  {
    id: "sala1",
    nombre: "Sala 1",
    subtitulo: "El Billar",
    video: "/ig/reel1.mp4",
    descripcion: "Espacio amplio con mesa de billar, proyector y barra privada.",
    minimo: 300,
    aforamiento: "40–50 personas",
    waText: "Hola%2C%20me%20interesa%20reservar%20la%20Sala%201",
    tickets: [
      { tipo: "2 Consumiciones", precio: 12, descripcion: "Incluye 2 consumiciones en barra" },
      { tipo: "Barra Libre", precio: 22, descripcion: "Vi, cerveza y cava ilimitado" },
      { tipo: "Barra Libre Combinados", precio: 32, descripcion: "Todo incluido — combinados ilimitados" },
    ],
    extras: ["Proyector para vídeos", "Puedes traer comida", "Decoración opcional"],
  },
  {
    id: "sala2",
    nombre: "Sala 2",
    subtitulo: "Premium Bar",
    video: "/ig/reel2.mp4",
    descripcion: "Sala de mayor capacidad con karaoke opcional, DJ y barra exclusiva.",
    minimo: 500,
    aforamiento: "Hasta 80 personas",
    waText: "Hola%2C%20me%20interesa%20reservar%20la%20Sala%202",
    tickets: [
      { tipo: "2 Consumiciones", precio: 15, descripcion: "Incluye 2 consumiciones en barra" },
      { tipo: "Barra Libre", precio: 25, descripcion: "Vi, cerveza y cava ilimitado" },
      { tipo: "Barra Libre Combinados", precio: 35, descripcion: "Todo incluido — combinados ilimitados" },
    ],
    extras: ["Karaoke opcional (+100€)", "DJ y Música Directa opcional", "Decoración de sala opcional", "Proyector para vídeos"],
  },
];
---

<section id="salas" class="py-20 px-4 bg-slate-950">
  <div class="max-w-6xl mx-auto">
    <!-- Header Refactorizado -->
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-6xl font-black text-white mb-6 tracking-tighter">
        ¿Qué quieres <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500">celebrar</span>?
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto mb-12">
        Desde una noche épica con amigos hasta el evento corporativo más exclusivo. En Estrop creamos el ambiente perfecto para ti.
      </p>
    </div>

    <!-- Flip Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {salas.map((sala) => (
        <div class="sala-flip-container aspect-[4/5]" id={`flip-${sala.id}`}>
          <div class="sala-flip-inner">

            <!-- CARA FRONTAL: Video -->
            <div class="sala-face sala-front rounded-2xl overflow-hidden">
              <video
                src={sala.video}
                autoplay
                muted
                loop
                playsinline
                class="absolute inset-0 w-full h-full object-cover"
              />
              <!-- Gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
              <!-- Content overlay -->
              <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
                <p class="text-pink-400 text-sm font-semibold uppercase tracking-widest mb-1">{sala.subtitulo}</p>
                <h3 class="text-4xl font-black text-white mb-2">{sala.nombre}</h3>
                <p class="text-slate-300 text-sm mb-6">{sala.descripcion}</p>
                <button
                  class="flip-btn w-full py-3 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 text-white font-semibold hover:bg-pink-500/30 hover:border-pink-400 transition-all duration-300 flex items-center justify-center gap-2"
                  data-target={`flip-${sala.id}`}
                >
                  <span>Ver precios y reservar</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
              </div>
            </div>

            <!-- CARA TRASERA: Precios -->
            <div class="sala-face sala-back rounded-2xl p-8 bg-slate-900 border border-pink-500/30 overflow-y-auto">
              <div class="flex items-center justify-between mb-6">
                <div>
                  <p class="text-pink-400 text-xs font-semibold uppercase tracking-widest">{sala.subtitulo}</p>
                  <h3 class="text-2xl font-black text-white">{sala.nombre}</h3>
                </div>
                <button
                  class="flip-btn p-2 rounded-lg bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:border-white/30 transition-all"
                  data-target={`flip-${sala.id}`}
                  aria-label="Volver"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                </button>
              </div>

              <!-- Tickets -->
              <div class="space-y-3 mb-6">
                {sala.tickets.map((ticket, i) => (
                  <div class={`flex items-center justify-between p-4 rounded-xl border transition-all ${i === 2 ? 'bg-pink-500/10 border-pink-500/40' : 'bg-white/5 border-white/10'}`}>
                    <div>
                      <p class="text-white font-semibold text-sm">{ticket.tipo}</p>
                      <p class="text-slate-400 text-xs mt-0.5">{ticket.descripcion}</p>
                    </div>
                    <span class={`text-xl font-black ml-4 whitespace-nowrap ${i === 2 ? 'text-pink-400' : 'text-white'}`}>
                      {ticket.precio}€<span class="text-xs font-normal text-slate-400">/pers</span>
                    </span>
                  </div>
                ))}
              </div>

              <!-- Info rápida -->
              <div class="flex gap-4 mb-6 text-xs text-slate-400">
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-pink-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Mínimo {sala.minimo}€
                </div>
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-pink-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {sala.aforamiento}
                </div>
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-pink-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  18:30 – 23:00h
                </div>
              </div>

              <!-- CTA WhatsApp -->
              <a
                href={`https://wa.me/${WA_NUMBER}?text=${sala.waText}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2.5 w-full py-4 rounded-xl bg-green-500 hover:bg-green-600 text-white font-bold text-base transition-all hover:scale-[1.02] shadow-[0_0_20px_rgba(34,197,94,0.3)]"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                Reservar {sala.nombre}
              </a>
            </div>

          </div>
        </div>
      ))}
    </div>

    <!-- Nota informativa -->
    <p class="text-center text-slate-500 text-sm mt-10">
      📌 Horario de sala privada: 18:30–23:00h · A las 23h abrimos al público pero la fiesta continúa 🕺 · No se permite bebida del exterior
    </p>
  </div>
</section>

<style>
  .sala-flip-container {
    perspective: 1200px;
    position: relative;
  }

  .sala-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .sala-flip-container.flipped .sala-flip-inner {
    transform: rotateY(180deg);
  }

  .sala-face {
    position: absolute;
    inset: 0;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* Front: clickable by default, disabled when flipped */
  .sala-front {
    pointer-events: auto;
  }
  .sala-flip-container.flipped .sala-front {
    pointer-events: none;
  }

  /* Back: disabled by default, clickable when flipped */
  .sala-back {
    transform: rotateY(180deg);
    pointer-events: none;
  }
  .sala-flip-container.flipped .sala-back {
    pointer-events: auto;
  }
</style>

<script>
  document.querySelectorAll('.flip-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const container = document.getElementById(targetId);
      if (container) {
        container.classList.toggle('flipped');
        // Pause/resume video
        const video = container.querySelector('video');
        if (video) {
          container.classList.contains('flipped') ? video.pause() : video.play();
        }
      }
    });
  });
</script>
