---

<div id="social" class="max-w-7xl mx-auto px-4 sm:px-6 py-20 relative">
  <div class="text-center mb-12">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-white">Live from Estrop</h2>
    <p class="text-muted text-lg mt-4">Revive la noche. Haz clic en los Reels para verlos ahora mismo.</p>
  </div>

  <!-- Carousel View (Todas las pantallas) -->
  <swiper-container class="w-full" slides-per-view="1" breakpoints='{"640": {"slidesPerView": 2}, "1024": {"slidesPerView": 4}}' space-between="24" loop="true" autoplay-delay="3000">
    {feed.map((post) => (
      <swiper-slide>
        <div 
          class="group relative rounded-3xl overflow-hidden aspect-[4/5] bg-slate-900 border border-slate-800 cursor-pointer media-trigger shadow-lg"
          data-type={post.mediaType}
          data-url={post.mediaUrl}
        >
          {post.mediaType === 'VIDEO' ? (
            <video src={post.mediaUrl} poster={post.thumbnailUrl} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" autoplay muted loop playsinline loading="lazy"></video>
          ) : (
            <img src={post.mediaUrl} alt="Instagram Post" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          )}
          
          <!-- Overlay de interacción -->
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center gap-4">
            <div class="p-4 bg-primary/90 text-white rounded-full shadow-[0_0_15px_rgba(168,85,247,0.5)] transform scale-75 group-hover:scale-100 transition-transform duration-300">
              {post.mediaType === 'VIDEO' ? (
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M9 21H3v-6"></path><path d="M21 3l-7 7"></path><path d="M3 21l7-7"></path></svg>
              )}
            </div>
            <span class="text-white font-bold tracking-widest uppercase text-sm">Ver ahora</span>
          </div>

          <!-- Badgets -->
          {post.mediaType === 'VIDEO' && (
            <div class="absolute bottom-4 left-4 pointer-events-none">
               <span class="px-3 py-1 bg-accent/90 text-white text-xs font-bold rounded-full backdrop-blur-sm shadow-md">REEL</span>
            </div>
          )}
        </div>
      </swiper-slide>
    ))}
  </swiper-container>
</div>

<!-- Modal / Lightbox para reproducir los archivos in-page -->
<div id="instagram-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 backdrop-blur-md p-4 opacity-0 transition-opacity duration-300">
  <button id="close-modal" class="absolute top-6 right-6 z-50 bg-white/10 hover:bg-white/20 text-white p-3 rounded-full transition-colors cursor-pointer border border-white/20">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
  <div id="modal-content" class="w-full max-w-4xl max-h-[85vh] rounded-2xl overflow-hidden flex items-center justify-center shadow-[0_0_50px_rgba(168,85,247,0.2)] bg-black">
    <!-- El contenido multimedia se inyecta dinámicamente aquí -->
  </div>
</div>

<script>
  import { register } from 'swiper/element/bundle';
  register();

  // Script del Lightbox para reproducir en la misma página
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.media-trigger');
    const modal = document.getElementById('instagram-modal');
    const modalContent = document.getElementById('modal-content');
    const closeModalBtn = document.getElementById('close-modal');

    const closeModal = () => {
      if (modal) {
        modal.classList.remove('opacity-100');
        modal.classList.add('opacity-0');
        setTimeout(() => {
          modal.classList.remove('flex');
          modal.classList.add('hidden');
          // Vaciamos el contenedor para apagar el audio del video
          if (modalContent) modalContent.innerHTML = '';
        }, 300);
      }
    };

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const type = trigger.getAttribute('data-type');
        const url = trigger.getAttribute('data-url');
        
        if (modal && modalContent) {
          modalContent.innerHTML = '';
          
          if (type === 'VIDEO') {
            // Añadimos 'controls', 'autoplay' sin 'muted' para que se escuche al abrir
            modalContent.innerHTML = `<video src="${url}" class="w-full h-full object-contain bg-black max-h-[85vh]" controls autoplay playsinline></video>`;
          } else {
            modalContent.innerHTML = `<img src="${url}" class="w-full h-full object-contain bg-black max-h-[85vh]" />`;
          }
          
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          
          // Retraso minúsculo para permitir la transición CSS
          setTimeout(() => {
             modal.classList.remove('opacity-0');
             modal.classList.add('opacity-100');
          }, 10);
        }
      });
    });

    if (closeModalBtn) {
      closeModalBtn.addEventListener('click', closeModal);
    }
    
    // Cerrar al hacer clic fuera del contenido
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
    }
  });
</script>
