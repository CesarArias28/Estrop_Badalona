---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative not-prose bg-slate-950 text-slate-300']}>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Main 3-Column Grid -->
    <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-16 md:gap-12 lg:gap-24 py-16 w-full max-w-6xl mx-auto px-4">
      
      <!-- Column 1: Estrop -->
      <div class="flex flex-col flex-1 items-center md:items-start w-full">
        <h3 class="font-bold text-white text-lg mb-6 text-center md:text-left w-full">Estrop</h3>
        <nav class="flex flex-col items-center md:items-start space-y-4 text-sm text-slate-400">
          <a href="/#" class="hover:text-pink-500 transition-colors">Inicio</a>
          <a href="/#features" class="hover:text-pink-500 transition-colors">Nosotros</a>
          <a href="/#experiencia" class="hover:text-pink-500 transition-colors">Experiencia</a>
          <a href="/#salas" class="hover:text-pink-500 transition-colors">Salas</a>
          <a href="/#reservas" class="hover:text-pink-500 transition-colors">Reservas</a>
        </nav>
      </div>

      <!-- Column 2: Ubicación -->
      <div class="flex flex-col flex-1 items-center w-full max-w-sm">
        <h3 class="font-bold text-white text-lg mb-6 text-center w-full">Ubicación</h3>
        
        <div class="relative w-full h-40 rounded-xl overflow-hidden group mb-4">
          <iframe
            src="https://maps.google.com/maps?q=Riera%20de%20Matamoros,%2044,%2008911%20Badalona,%20Barcelona&t=&z=16&ie=UTF8&iwloc=&output=embed"
            class="absolute inset-0 w-full h-full border-0 filter grayscale-[30%] invert-[100%] hue-rotate-[180deg] saturate-[2] contrast-[1.1] opacity-70 transition-opacity duration-500 group-hover:opacity-90"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          
          <!-- Central Red Pin with Label -->
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 pointer-events-none flex flex-col items-center">
             <div class="bg-slate-900/90 text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-[0_0_10px_rgba(236,72,153,0.5)] border border-pink-500/50 mb-1">
               ESTROP
             </div>
             <div class="w-1 h-3 bg-pink-500"></div>
             <div class="w-2 h-2 rounded-full bg-pink-600 shadow-[0_0_8px_rgba(236,72,153,1)]"></div>
          </div>
          
          <a href="https://maps.google.com/maps?q=Riera%20de%20Matamoros,+44,+08911+Badalona,+Barcelona" target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10" aria-label="Abrir en Google Maps"></a>
        </div>
        
        <!-- Address text with icon -->
        <div class="flex flex-col md:flex-row items-center md:items-start gap-3 text-sm text-slate-400 hover:text-slate-200 transition-colors text-center md:text-left">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 text-pink-500 mt-0 md:mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <a href="https://maps.google.com/maps?q=Riera%20de%20Matamoros,+44,+08911+Badalona,+Barcelona" target="_blank" rel="noopener noreferrer">
            Riera de Matamoros, 44,<br class="hidden md:block"> 08911 Badalona, Barcelona
          </a>
        </div>
      </div>

      <!-- Column 3: Legal y Contacto -->
      <div class="flex flex-col flex-1 items-center md:items-start w-full">
        <h3 class="font-bold text-white text-lg mb-6 text-center md:text-left w-full">Legal y Contacto</h3>
        <nav class="flex flex-col items-center md:items-start space-y-4 text-sm text-slate-400 mb-8">
          <a href="#" class="hover:text-pink-500 transition-colors">Términos y Condiciones</a>
          <a href="#" class="hover:text-pink-500 transition-colors">Política de Privacidad</a>
        </nav>
        
        <div class="flex flex-col items-center md:items-start space-y-4 text-sm text-slate-400 mb-8">
          <div class="flex flex-col md:flex-row items-center gap-2 md:gap-3">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
             </svg>
             <span>+34 600 00 00 00</span>
          </div>
          <div class="flex flex-col md:flex-row items-center gap-2 md:gap-3">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
             </svg>
             <span>contacto@estrop.com</span>
          </div>
        </div>

        <div class="flex gap-4">
          <a href="https://www.instagram.com/estropbadalona/?hl=es" target="_blank" rel="noopener noreferrer" class="p-2 rounded-full bg-slate-900 border border-slate-800 hover:border-pink-500 hover:bg-slate-800 transition-colors text-slate-300 hover:text-white" aria-label="Instagram">
             <Icon name="tabler:brand-instagram" class="w-5 h-5" />
          </a>
          <a href="#" class="p-2 rounded-full bg-slate-900 border border-slate-800 hover:border-pink-500 hover:bg-slate-800 transition-colors text-slate-300 hover:text-white" aria-label="Facebook">
             <Icon name="tabler:brand-facebook" class="w-5 h-5" />
          </a>
        </div>
      </div>

    </div>
    
    <!-- Bottom Bar -->
    <div class="border-t border-slate-800 py-6 text-sm text-slate-500 flex flex-col md:flex-row items-center md:items-start justify-start">
      <p>© 2026 Estrop Bar Musical · Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
