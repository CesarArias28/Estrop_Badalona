---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative not-prose bg-slate-950 text-slate-300']}>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Main 4-Column Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12 lg:gap-24 py-16 w-full max-w-6xl mx-auto px-4">
      
      <!-- Column 1: Estrop -->
      <div class="flex flex-col">
        <h3 class="font-bold text-white text-lg mb-6">Estrop</h3>
        <nav class="flex flex-col space-y-4 text-sm text-slate-400">
          <a href="/#" class="hover:text-pink-500 transition-colors">Inicio</a>
          <a href="/#features" class="hover:text-pink-500 transition-colors">Nosotros</a>
          <a href="/#experiencia" class="hover:text-pink-500 transition-colors">Experiencia</a>
          <a href="/#salas" class="hover:text-pink-500 transition-colors">Salas</a>
          <a href="/#reservas" class="hover:text-pink-500 transition-colors">Reservas</a>
        </nav>
      </div>

      <!-- Column 2: Ubicación -->
      <div class="flex flex-col w-full max-w-sm">
        <h3 class="font-bold text-white text-lg mb-6">Ubicación</h3>
        
        <div class="relative w-full h-40 rounded-xl overflow-hidden group mb-4">
          <iframe
            src="https://maps.google.com/maps?q=L%27Estrop%20Badalona&t=&z=16&ie=UTF8&iwloc=&output=embed"
            class="absolute inset-0 w-full h-full border-0 filter grayscale-[30%] invert-[100%] hue-rotate-[180deg] saturate-[2] contrast-[1.1] opacity-70 transition-opacity duration-500 group-hover:opacity-90"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          
          <!-- Central Red Pin with Label -->
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 pointer-events-none flex flex-col items-center">
             <div class="bg-slate-900/90 text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-[0_0_10px_rgba(236,72,153,0.5)] border border-pink-500/50 mb-1">
               ESTROP
             </div>
             <div class="w-1 h-3 bg-pink-500"></div>
             <div class="w-2 h-2 rounded-full bg-pink-600 shadow-[0_0_8px_rgba(236,72,153,1)]"></div>
          </div>
          
          <a href="https://maps.google.com/maps?q=L%27Estrop+Badalona" target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10" aria-label="Abrir en Google Maps"></a>
        </div>
        
        <!-- Address text with icon -->
        <div class="flex items-start gap-3 text-sm text-slate-400 hover:text-slate-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 text-pink-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <a href="https://maps.google.com/maps?q=L%27Estrop+Badalona" target="_blank" rel="noopener noreferrer">
            Riera de Matamoros, 44,<br> 08911 Badalona, Barcelona
          </a>
        </div>
      </div>

      <!-- Column 3: Horarios -->
      <div id="horarios" class="flex flex-col scroll-mt-24 w-full max-w-xs">
        <h3 class="font-bold text-white text-lg mb-6">Horarios</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex justify-between items-center border-b border-slate-900 pb-2">
            <span class="text-white font-medium">Miércoles</span>
            <span class="text-slate-300">19:00 - 02:00</span>
          </li>
          <li class="flex justify-between items-center border-b border-slate-900 pb-2">
            <span class="text-white font-medium">Jueves</span>
            <span class="text-slate-300">20:00 - 02:30</span>
          </li>
          <li class="flex justify-between items-center border-b border-slate-900 pb-2">
            <span class="text-white font-medium">Viernes</span>
            <span class="text-slate-300">18:00 - 03:30</span>
          </li>
          <li class="flex justify-between items-center border-b border-slate-900 pb-2">
            <span class="text-white font-medium">Sábado</span>
            <span class="text-slate-300">18:00 - 03:30</span>
          </li>
          <li class="flex justify-between items-center border-b border-slate-900 pb-2">
            <span class="text-white font-medium">Domingo</span>
            <span class="text-slate-300">20:00 - 02:30</span>
          </li>
          <li class="flex justify-between items-center pb-2">
            <span class="text-white font-medium">Lunes y Martes</span>
            <span class="text-[#ff007f] font-semibold drop-shadow-[0_0_8px_rgba(255,0,127,0.35)]">Cerrado</span>
          </li>
        </ul>
      </div>

      <!-- Column 4: Legal y Contacto -->
      <div class="flex flex-col">
        <h3 class="font-bold text-white text-lg mb-6">Legal y Contacto</h3>
        <nav class="flex flex-col space-y-4 text-sm text-slate-400 mb-8">
          <a href="#" id="trigger-terms" class="hover:text-pink-500 transition-colors">Términos y Condiciones</a>
          <a href="#" id="trigger-privacy" class="hover:text-pink-500 transition-colors">Política de Privacidad</a>
        </nav>
        
        <div class="flex flex-col space-y-4 text-sm text-slate-400 mb-8">
          <div class="flex items-center gap-3">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
             </svg>
             <a href="tel:+34609550930" class="hover:text-pink-500 transition-colors">+34 609 550 930</a>
          </div>
          <div class="flex items-center gap-3">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
             </svg>
             <a href="mailto:eduardcg10@gmail.com" class="hover:text-pink-500 transition-colors">eduardcg10@gmail.com</a>
          </div>
        </div>

        <div class="flex gap-4">
          <a href="https://www.instagram.com/estropbadalona/?hl=es" target="_blank" rel="noopener noreferrer" class="p-2 rounded-full bg-slate-900 border border-slate-800 hover:border-pink-500 hover:bg-slate-800 transition-colors text-slate-300 hover:text-white" aria-label="Instagram">
             <Icon name="tabler:brand-instagram" class="w-5 h-5" />
          </a>
          <a href="#" class="p-2 rounded-full bg-slate-900 border border-slate-800 hover:border-pink-500 hover:bg-slate-800 transition-colors text-slate-300 hover:text-white" aria-label="Facebook">
             <Icon name="tabler:brand-facebook" class="w-5 h-5" />
          </a>
        </div>
      </div>

    </div>
    
    <!-- Bottom Bar -->
    <div class="border-t border-slate-800 py-6 text-sm text-slate-500 flex flex-col md:flex-row items-center md:items-start justify-start">
      <p>© 2026 Estrop Bar Musical · Todos los derechos reservados.</p>
    </div>
  </div>

  <!-- Legal Modal (Glassmorphic & Scrollable) -->
  <div id="legal-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300">
    <div class="relative w-full max-w-2xl bg-slate-950/95 border border-slate-800 rounded-2xl shadow-[0_0_50px_rgba(236,72,153,0.15)] flex flex-col max-h-[85vh] transition-transform duration-300">
      <!-- Modal Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-slate-900">
        <h3 id="legal-modal-title" class="text-xl font-bold text-white tracking-tight"></h3>
        <button id="close-legal-modal" class="text-slate-400 hover:text-white p-1 rounded-lg hover:bg-slate-900 transition-colors" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <!-- Modal Body (Scrollable content) -->
      <div class="flex-1 overflow-y-auto p-6 text-sm text-slate-300 space-y-6 leading-relaxed select-text">
        
        <!-- Content: Privacy Policy -->
        <div id="legal-privacy" class="hidden space-y-6">
          <div class="space-y-4">
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1">1. Responsable del Tratamiento de Datos</h4>
            <p>
              <strong>Identidad:</strong> L'estrop 2021 sl (en adelante, "Estrop Bar Musical")<br>
              <strong>NIF/CIF:</strong> B05388962<br>
              <strong>Dirección:</strong> Riera de Matamoros, 44, 08911 Badalona, Barcelona<br>
              <strong>Correo electrónico:</strong> <a href="mailto:eduardcg10@gmail.com" class="text-pink-400 hover:underline">eduardcg10@gmail.com</a>
            </p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">2. Finalidad del Tratamiento</h4>
            <p>En Estrop Bar Musical tratamos la información que nos facilitan las personas interesadas con el fin principal de gestionar las reservas de mesas o salas y atender consultas generales sobre nuestros servicios y horarios. La comunicación para estas gestiones se realiza de forma exclusiva a través de la aplicación WhatsApp.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">3. Legitimación</h4>
            <p>La base legal para el tratamiento de sus datos es el consentimiento expreso del interesado. Al iniciar una conversación mediante nuestro canal de WhatsApp para solicitar una reserva o información, el usuario consiente explícitamente el tratamiento de su número de teléfono y nombre de perfil para dicha finalidad.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">4. Conservación de los Datos</h4>
            <p>Los datos personales proporcionados se conservarán mientras se mantenga la relación comercial (es decir, hasta que se haga efectiva la reserva) y no se solicite su supresión por el interesado. Periódicamente, Estrop Bar Musical procederá a la eliminación de historiales de chat antiguos que ya no sean necesarios para la gestión del local. No utilizaremos su número para enviar publicidad masiva (spam) sin solicitar un consentimiento adicional específico.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">5. Destinatarios</h4>
            <p>Los datos no se cederán a terceros, salvo obligación legal. Cabe destacar que, al utilizar WhatsApp como medio de comunicación, el usuario también está sujeto a las políticas de privacidad de WhatsApp Ireland Limited (Meta).</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">6. Derechos del Usuario</h4>
            <p>Cualquier persona tiene derecho a obtener confirmación sobre si en Estrop Bar Musical estamos tratando datos personales que les conciernan. Las personas interesadas tienen derecho a acceder a sus datos personales, así como a solicitar la rectificación de los datos inexactos o, en su caso, solicitar su supresión. Para ejercer estos derechos, puede enviar un correo electrónico a <a href="mailto:eduardcg10@gmail.com" class="text-pink-400 hover:underline">eduardcg10@gmail.com</a> indicando en el asunto "Protección de Datos".</p>
          </div>
        </div>
        
        <!-- Content: Terms of Booking -->
        <div id="legal-terms" class="hidden space-y-6">
          <div class="space-y-4">
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1">1. Proceso de Reserva</h4>
            <p>Todas las solicitudes de reserva se gestionan a través de nuestro canal oficial de WhatsApp.</p>
            <p>La reserva no se considerará confirmada hasta que el cliente reciba un mensaje de confirmación explícito por parte de nuestro equipo.</p>
            <p>No se exige ningún pago anticipado a través de la página web para formalizar la reserva estándar. Todos los pagos de consumiciones se realizarán de forma presencial en el local.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">2. Política de Retrasos y Cancelaciones</h4>
            <p><strong>Cancelaciones:</strong> Rogamos a nuestros clientes que, en caso de no poder asistir, lo comuniquen a través de WhatsApp con la mayor antelación posible para facilitar la organización del local.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">3. Derecho de Admisión y Acceso</h4>
            <p><strong>Edad mínima:</strong> El acceso a Estrop Bar Musical está restringido a personas mayores de 18 años. El personal de puerta o barra podrá solicitar un documento de identidad físico (DNI, NIE o Pasaporte) para verificar la edad.</p>
            <p><strong>Derecho de admisión:</strong> Estrop Bar Musical se reserva el derecho de admisión de acuerdo con la legislación vigente en Cataluña. No se permitirá el acceso a personas que manifiesten comportamientos violentos, que se encuentren bajo evidentes efectos del alcohol o estupefacientes, o que alteren el normal desarrollo de la actividad del local.</p>
            <p><strong>Aforo:</strong> El acceso al local y a las salas reservadas está sujeto en todo momento a los límites de aforo legal establecidos.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">4. Pagos y Consumiciones</h4>
            <p>El pago de las bebidas, botellas o servicios consumidos se realizará íntegramente en las instalaciones de Estrop Bar Musical.</p>
            <p>Se aceptan pagos en efectivo y con tarjeta de crédito/débito en el propio establecimiento.</p>
            
            <h4 class="text-white font-bold text-base border-b border-slate-900 pb-1 mt-6">5. Modificaciones</h4>
            <p>Estrop Bar Musical se reserva el derecho a modificar las presentes condiciones en cualquier momento, siendo aplicables aquellas que estén publicadas en la página web en el momento de realizar la solicitud de reserva.</p>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</footer>

<script>
  const modal = document.getElementById('legal-modal');
  const modalTitle = document.getElementById('legal-modal-title');
  const closeBtn = document.getElementById('close-legal-modal');
  const contentPrivacy = document.getElementById('legal-privacy');
  const contentTerms = document.getElementById('legal-terms');

  const openModal = (type: 'privacy' | 'terms') => {
    if (!modal) return;
    if (type === 'privacy') {
      if (contentPrivacy) contentPrivacy.classList.remove('hidden');
      if (contentTerms) contentTerms.classList.add('hidden');
      if (modalTitle) modalTitle.textContent = 'Política de Privacidad';
    } else {
      if (contentPrivacy) contentPrivacy.classList.add('hidden');
      if (contentTerms) contentTerms.classList.remove('hidden');
      if (modalTitle) modalTitle.textContent = 'Condiciones de Reserva';
    }
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    setTimeout(() => {
      modal.classList.remove('opacity-0');
      modal.classList.add('opacity-100');
    }, 10);
    document.body.classList.add('overflow-hidden');
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.remove('opacity-100');
    modal.classList.add('opacity-0');
    setTimeout(() => {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    }, 300);
    document.body.classList.remove('overflow-hidden');
  };

  const triggerTerms = document.getElementById('trigger-terms');
  const triggerPrivacy = document.getElementById('trigger-privacy');

  if (triggerTerms) {
    triggerTerms.addEventListener('click', (e) => {
      e.preventDefault();
      openModal('terms');
    });
  }
  if (triggerPrivacy) {
    triggerPrivacy.addEventListener('click', (e) => {
      e.preventDefault();
      openModal('privacy');
    });
  }
  if (closeBtn) {
    closeBtn.addEventListener('click', closeModal);
  }
  if (modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }
  
  // Close on Escape key press
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
