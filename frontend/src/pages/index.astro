---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Showroom from '~/components/widgets/Showroom.astro';
import Salas from '~/components/widgets/Salas.astro';
import LiveFromEstrop from '~/components/widgets/LiveFromEstrop.astro';

const metadata = {
  title: 'Estrop | Bar Musical, Tardeo y Eventos en Badalona',
  description: 'El mejor ambiente de Badalona. Disfruta del Tardeo, sesiones exclusivas de DJ, música en directo y salas privadas para celebrar tu cumpleaños o evento de empresa. Reserva tu mesa directamente por WhatsApp.',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    locale: 'es_ES',
    siteName: 'Estrop Bar Musical',
    title: 'Estrop | El Bar Musical de Referencia en Badalona',
    description: 'Tardeos, copas premium y los mejores DJs en Badalona. Reserva tu sala privada ahora.',
    images: [
      {
        url: '~/assets/images/default.png',
        width: 1200,
        height: 628,
      },
    ],
  },
};
---

<Layout metadata={metadata}>
  <!-- Custom Hero Section matching reference layout -->
  <section class="relative h-[90vh] w-full flex flex-col items-center justify-center overflow-hidden bg-slate-950 mt-[-80px]">
    <!-- Background Image (Crowd Dancing) -->
    <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?q=80&w=2000&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-screen" alt="Gente bailando en club nocturno" />
    
    <!-- Gradient Overlay for smooth transition to next section -->
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-slate-900/40 z-0"></div>

    <!-- Main Content Container -->
    <div class="relative z-10 w-full flex items-center justify-center h-full px-4">
      <!-- Massive Neon Text (Like CLASS TICKETS) -->
      <h1 class="text-[clamp(4rem,15vw,18rem)] font-black text-transparent bg-clip-text bg-gradient-to-br from-pink-400 via-pink-500 to-purple-600 drop-shadow-[0_0_60px_rgba(236,72,153,0.7)] uppercase tracking-tighter leading-none text-center transform -skew-x-6 whitespace-nowrap">
        ESTROP
      </h1>
      

    </div>

    <!-- Call to Action Buttons -->
    <div class="absolute bottom-12 z-30 flex flex-col sm:flex-row items-center gap-6">
      <a href="https://wa.me/15556389717?text=Hola%2C%20quiero%20reservar%20en%20Estrop" target="_blank" class="flex items-center gap-2 px-8 py-4 bg-green-500 hover:bg-green-600 text-white font-bold rounded-full shadow-[0_0_20px_rgba(34,197,94,0.6)] animate-heartbeat transition-all text-lg uppercase tracking-wider">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        Reservar Sala
      </a>
      <a href="#salas" class="px-8 py-4 bg-transparent border-2 border-pink-500 text-pink-500 hover:bg-pink-500 hover:text-white font-bold rounded-full transition-colors text-lg uppercase tracking-wider backdrop-blur-sm">
        Ver Eventos
      </a>
    </div>
  </section>

  <!-- Features Grid (¿Por qué nosotros?) -->
  <Features
    id="features"
    tagline="¿Por qué nosotros?"
    title="La experiencia Estrop"
    subtitle="Descubre lo que nos hace únicos y por qué somos el lugar de referencia."
    items={[
      {
        title: 'Juegos y Karaoke',
        description: 'Reta a tus amigos al billar, futbolín o dardos. Además, todos los jueves disfruta de nuestras noches de karaoke con entrada libre.',
        icon: 'tabler:device-gamepad',
      },
      {
        title: 'Música en Directo & DJs',
        description: 'Cada fin de semana contamos con los mejores DJs y sesiones de música en directo para animar la noche.',
        icon: 'tabler:music',
      },
      {
        title: 'Cócteles de Autor',
        description: 'Nuestros bartenders preparan mezclas únicas. Atrévete a probar nuestras especialidades.',
        icon: 'tabler:glass-cocktail',
      },
      {
        title: 'Eventos Privados',
        description: 'Celebra tu cumpleaños, despedida o evento de empresa con nosotros en un espacio exclusivo.',
        icon: 'tabler:confetti',
      },
    ]}
  />

  <!-- El Showroom (Cartas de Experiencia) -->
  <Showroom />

  <!-- Salas Privadas (Flip Cards) -->
  <Salas />

  <!-- Feed de Instagram (Bento Grid) -->
  <LiveFromEstrop />

  <!-- Formulario / CTA WhatsApp (Fase Inicial) -->
  <div id="reservas" class="max-w-4xl mx-auto p-4 sm:p-6 mb-12">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-primary">Reserva tu evento</h2>
      <p class="text-muted text-lg mt-4">Habla con nuestro asistente para gestionar tu reserva rápidamente por WhatsApp.</p>
    </div>
    
    <div class="bg-slate-900/50 backdrop-blur-md rounded-2xl p-10 text-center flex flex-col items-center justify-center border border-primary/30 shadow-[0_0_15px_rgba(168,85,247,0.2)] hover:shadow-[0_0_25px_rgba(168,85,247,0.4)] transition-shadow duration-300">
      <span class="p-5 bg-green-500 text-white rounded-full mb-6 shadow-[0_0_20px_rgba(34,197,94,0.4)] animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
          <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
        </svg>
      </span>
      <h3 class="text-2xl font-bold text-white mb-4">¿Listo para la mejor noche?</h3>
      <p class="text-muted mb-8 max-w-md mx-auto">Haz clic abajo y envíanos un mensaje. Nuestro bot te ayudará a encontrar la mesa perfecta en segundos.</p>
      
      <a 
        href="https://wa.me/15556389717?text=Hola%2C%20quiero%20reservar%20en%20Estrop%2044" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-green-500 hover:bg-green-600 text-white font-bold text-lg px-8 py-4 transition-transform hover:scale-105"
      >
        Reservar por WhatsApp
      </a>
    </div>
  </div>

</Layout>
